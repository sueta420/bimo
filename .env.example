# Core
TESTNET=true
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_HTTP_TIMEOUT_SEC=20

# OpenAI (optional, for explain/rank only)
ENABLE_LLM=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
USE_LLM_SECONDARY_RANK=false
LLM_RANK_TOP_N=3
LLM_RANK_MIN_SCORE=72
LLM_RANK_MAX_SCORE_SPREAD=6

# Risk model
POSITION_SIZING_MODE=risk_pct
RISK_PER_TRADE_PCT=0.5
RISK_PER_TRADE_USD=0
TARGET_NOTIONAL_USD=5
TARGET_MARGIN_USD=0
TARGET_RISK_USD=0
MIN_RISK_UTILIZATION=0
TARGET_LEVERAGE=1
DYNAMIC_LEVERAGE_ENABLED=false
FAKEOUT_TARGET_LEVERAGE=3
BREAKOUT_TARGET_LEVERAGE=5
REVERSAL_TARGET_LEVERAGE=2
DYNAMIC_LEVERAGE_HIGH_SCORE=80
DYNAMIC_LEVERAGE_LOW_SCORE=72
DYNAMIC_LEVERAGE_HIGH_SCORE_BONUS=1
DYNAMIC_LEVERAGE_LOW_SCORE_CUT=1
DYNAMIC_LEVERAGE_HIGH_ATR_RATIO=0.012
DYNAMIC_LEVERAGE_HIGH_ATR_CUT=1
MAX_RISK_PER_TRADE_USD=0
MIN_RR_RATIO=3.0
MIN_EDGE_COST_RATIO=2.0
MIN_NET_REWARD_PCT=0.25
MAX_SIDE_RISK_PCT=1.5
MAX_SIDE_RISK_USD=0
SLIPPAGE_ENTRY_BPS=10
SLIPPAGE_EXIT_BPS=15
TAKER_FEE_BPS=5.5
FUNDING_RESERVE_RATE=0.0005
MAX_LEVERAGE=10

# Universe / filters
MIN_VOLUME_24H=25000000
MAX_SCAN_SYMBOLS=20
SYMBOL_BLACKLIST=
MAX_FUNDING_ABS=0.001
MIN_ATR_RATIO=0.005
MIN_ATR_RATIO_MAJORS=0.0020
MAJOR_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,ADAUSDT,LINKUSDT,DOGEUSDT
FAKEOUT_EDGE_MAX_FRAC=0.18
FAKEOUT_MAX_ATR_RATIO=0.014
FAKEOUT_MAX_OI_CHANGE_PCT=2.0
FAKEOUT_MIN_VOL_RATIO=60
ENTRY_TF=15
REGIME_TF_1=60
REGIME_TF_2=240
MIN_RULE_SCORE=70
FUNDING_BLOCK_MINUTES=10
OI_SPIKE_BLOCK_PCT=8
RANGE_MID_AVOID_PCT=0.30
SYMBOL_COOLDOWN_MIN=120
CORRELATION_THRESHOLD=0.85
MAX_CORRELATED_POSITIONS_PER_SIDE=2
CORRELATION_LOOKBACK=96
SESSION_TIMEZONE=UTC

# Position management
BE_TRIGGER_R=1.0
TRAILING_TRIGGER_R=1.5
TRAILING_LOCK_R=0.8

# Session limits
MAX_TRADES_PER_DAY=5
STOP_AFTER_LOSSES=3
ENABLE_EOD_CLOSE=true
CLOSE_HOUR_UTC=23
CLOSE_MIN_UTC=45
CYCLE_SEC=900
BYBIT_READ_RETRIES=2
BYBIT_READ_RETRY_DELAY_MS=800
CLOSE_VERIFY_RETRIES=6
CLOSE_VERIFY_DELAY_MS=500
CRITICAL_ERROR_STOP_COUNT=3

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TG_MIN_INTERVAL_SEC=3
TG_ERROR_COOLDOWN_SEC=180
TG_TIMEOUT_SEC=10

# State/logging
STATE_DB_PATH=./agent_state.sqlite3
REPORTS_DIR=./reports
WATCHDOG_HEARTBEAT_GRACE_SEC=1800
WATCHDOG_RESTART_COOLDOWN_SEC=1800
WATCHDOG_LAUNCHD_LABEL=com.trading.agent
LOG_JSON=true
