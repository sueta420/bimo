# Core
TESTNET=true
BYBIT_API_KEY=
BYBIT_API_SECRET=

# OpenAI (optional, for explain/rank only)
ENABLE_LLM=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
USE_LLM_SECONDARY_RANK=false
LLM_RANK_TOP_N=3
LLM_RANK_MIN_SCORE=72
LLM_RANK_MAX_SCORE_SPREAD=6

# Risk model
POSITION_SIZING_MODE=risk_pct
RISK_PER_TRADE_PCT=0.5
RISK_PER_TRADE_USD=0
TARGET_NOTIONAL_USD=5
MAX_RISK_PER_TRADE_USD=0
MIN_RR_RATIO=3.0
MIN_EDGE_COST_RATIO=2.0
MIN_NET_REWARD_PCT=0.25
MAX_SIDE_RISK_PCT=1.5
SLIPPAGE_ENTRY_BPS=10
SLIPPAGE_EXIT_BPS=15
TAKER_FEE_BPS=5.5
FUNDING_RESERVE_RATE=0.0005
MAX_LEVERAGE=10

# Universe / filters
MIN_VOLUME_24H=50000000
MAX_FUNDING_ABS=0.001
MIN_ATR_RATIO=0.005
ENTRY_TF=15
REGIME_TF_1=60
REGIME_TF_2=240
MIN_RULE_SCORE=60
FUNDING_BLOCK_MINUTES=10
OI_SPIKE_BLOCK_PCT=8
RANGE_MID_AVOID_PCT=0.25
SYMBOL_COOLDOWN_MIN=120
CORRELATION_THRESHOLD=0.85
MAX_CORRELATED_POSITIONS_PER_SIDE=2
CORRELATION_LOOKBACK=96
SESSION_TIMEZONE=UTC

# Position management
BE_TRIGGER_R=1.0
TRAILING_TRIGGER_R=1.5
TRAILING_LOCK_R=0.8

# Session limits
MAX_TRADES_PER_DAY=5
STOP_AFTER_LOSSES=3
ENABLE_EOD_CLOSE=true
CLOSE_HOUR_UTC=23
CLOSE_MIN_UTC=45
CYCLE_SEC=900
CLOSE_VERIFY_RETRIES=6
CLOSE_VERIFY_DELAY_MS=500
CRITICAL_ERROR_STOP_COUNT=3

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TG_MIN_INTERVAL_SEC=3
TG_ERROR_COOLDOWN_SEC=180
TG_TIMEOUT_SEC=10

# State/logging
STATE_DB_PATH=./agent_state.sqlite3
LOG_JSON=true
